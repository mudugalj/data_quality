# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Test / tooling caches ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Dask ----
dask-worker-space/

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
*.swp

# ---- Generated demo artifacts ----
# Mock Parquet is reproducible via data/create_parquet.py
data/**/*.parquet
# Run outputs are reproducible via the engine + data/seed_history.py
output/*.csv

# Keep the output/ directory in the repo (tracked, but empty of artifacts)
!output/.gitkeep
